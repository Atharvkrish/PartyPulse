{
  "buildCommand": "pnpm --filter @workspace/partypulse run build",
  "outputDirectory": "artifacts/partypulse/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
