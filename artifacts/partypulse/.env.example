# ─── PartyPulse environment variables ────────────────────────────────────────
# Copy this file to .env.local for local development.
# In Replit: add these as Secrets (sidebar → Secrets tab).
# In Vercel: add these under Project → Settings → Environment Variables.
#
# All variables MUST start with VITE_ to be accessible in client-side code
# via import.meta.env.VITE_*. Variables without the VITE_ prefix are
# invisible to the browser bundle (Vite's security default).
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase ──────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Ticketmaster Discovery API ────────────────────────────────────────────────
# Get your key at: https://developer.ticketmaster.com/
# IMPORTANT: Use your PRODUCTION key with the production base URL:
#   https://app.ticketmaster.com/discovery/v2/
# Staging keys will return 401 against the production URL.
# The free tier allows 5,000 API calls/day.
VITE_TICKETMASTER_API_KEY=your_ticketmaster_api_key_here
