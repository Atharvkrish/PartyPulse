# PartyPulse — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (required) ───────────────────────────────────────────────────────
# Copy from Firebase Console → Project Settings → Your apps → Web app → Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abc123def456

# ── Ticketmaster ──────────────────────────────────────────────────────────────
#
# ⚠️  SERVER-SIDE ONLY — do NOT prefix with VITE_
#    A VITE_ prefix bundles the value into the client JS bundle, exposing the
#    key publicly to anyone who views source. It belongs on the server only,
#    where it is used by the /api/ticketmaster Vercel serverless proxy.
#
# Where to set it:
#   • Local (vercel dev):    add to .env.local as TICKETMASTER_API_KEY=...
#   • Production / Preview:  Vercel → Project → Settings → Environment Variables
#
# Get your key at: https://developer.ticketmaster.com/
# Use the PRODUCTION key — staging keys return 401 against the production URL.
TICKETMASTER_API_KEY=your_ticketmaster_production_api_key

# ── Removed ───────────────────────────────────────────────────────────────────
#
# VITE_TICKETMASTER_API_KEY — NO LONGER USED. Safe to delete from Replit Secrets
# and Vercel Environment Variables. The Ticketmaster key has been moved server-side
# into the Vercel proxy at api/ticketmaster.ts, which eliminates the CORS issue
# and prevents the key from ever reaching the browser bundle.
